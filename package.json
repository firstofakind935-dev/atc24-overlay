{
  "name": "atc24-overlay",
  "version": "1.0.0",
  "description": "ATC24 Flight Plan Generator Overlay",
  "main": "main.js",
  "author": "Cmaci",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64",
    "test": "node test/perf.test.js"
  },
  "build": {
    "appId": "com.cmaci.atc24overlay",
    "productName": "ATC24 Overlay",
    "asar": false,
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "perf.js",
      "icon.png"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.png"
    }
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^25.1.8"
  }
}
